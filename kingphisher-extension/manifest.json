{
  "manifest_version": 3,
  "name": "KingPhisher",
  "version": "1.0",
  "description": "Detection and prevention platform for phishing, credential theft, and QR phishing",
  "permissions": ["tabs", "activeTab", "storage", "history"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
